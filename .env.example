TIMESCALEDB_HOST=127.0.0.1
TIMESCALEDB_PORT=54321
TIMESCALEDB_USER=crypto
TIMESCALEDB_PASSWORD=change_me
TIMESCALEDB_DB=crypto
PGSSLMODE=disable

L2_HTTP_TIMEOUT_S=60
L2_HTTP_MAX_RETRIES=10
L2_HTTP_RETRY_BACKOFF_S=2

L2_SYNC_LOG_DIR=/volume1/Temp/logs
L2_FETCH_CONCURRENCY=8

L2_INGEST_EXCHANGE=deribit
L2_INGEST_SYMBOLS=BTC ETH
L2_INGEST_LEVELS=50
L2_INGEST_SNAPSHOT_COUNT=5
L2_INGEST_POLL_INTERVAL_S=10
L2_INGEST_MAX_RUNTIME_S=55
L2_INGEST_SAVE_PARQUET_LAKE=true
L2_INGEST_LAKE_ROOT=lake/bronze
L2_INGEST_NO_JSON_OUTPUT=true
